# 复制到 /etc/cip/cip.env 后，在服务器本机修改。
# 不要把真实 API 地址、Token、Chat ID、换 IP 接口提交到 GitHub。

SCRIPT_NAME="CIP Monitor"
DEVICE_NAME="my-server-01"

# 使用 auto 表示检测服务器当前公网 IPv4。
TARGET_ADDRESS="auto"
TARGET_PORT=""

# 端口检测 API。脚本会请求：
#   CHECK_API_URL?address=<ip>&port=<port>
#   CHECK_API_URL_2?address=<ip>&port=<port>
# 返回 JSON 需要包含 code=200、address=<ip>、port=<port>。
CHECK_API_URL=""
CHECK_API_URL_2=""

CHECK_INTERVAL="30"
MAX_FAILURES="3"

# 两个检测 API 连续失败 MAX_FAILURES 次后调用这个换 IP 地址。
SWITCH_IP_URL=""
SWITCH_WAIT_SECONDS="10"
SWITCH_COOLDOWN_SECONDS="120"

# Telegram 推送配置，留空表示不推送。
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
