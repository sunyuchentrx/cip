# Copy this file to /etc/cip/cip.env and edit it on your server.
# Do not commit real API URLs, tokens, chat IDs, or private service URLs.

SCRIPT_NAME="CIP Monitor"

# Use auto to monitor the server's current public IPv4 address.
TARGET_ADDRESS="auto"
TARGET_PORT=""

# Port check API endpoints. The monitor calls:
#   CHECK_API_URL?address=<ip>&port=<port>
#   CHECK_API_URL_2?address=<ip>&port=<port>
# Expected JSON includes code=200, address=<ip>, port=<port>.
CHECK_API_URL=""
CHECK_API_URL_2=""

CHECK_INTERVAL="30"
MAX_FAILURES="3"

# URL called when both check APIs fail MAX_FAILURES times.
SWITCH_IP_URL=""
SWITCH_WAIT_SECONDS="10"
SWITCH_COOLDOWN_SECONDS="120"

# Optional Telegram notification settings. Leave empty to disable.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
